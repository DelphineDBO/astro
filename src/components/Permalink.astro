---
// Ligne « Lien permanent » avec bouton copier.
// L'URL complète est calculée au build depuis `site` + `base` (astro.config.mjs).
const permalink = new URL(Astro.url.pathname, Astro.site).href;
---
<div class="permalink">
  <span class="permalink-label">Lien permanent :</span>
  <a class="permalink-url" href={permalink}>{permalink}</a>
  <button type="button" class="permalink-copy" data-copy={permalink} aria-label="Copier le lien" title="Copier le lien">
    <svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    <svg class="icon-check" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  </button>
</div>

<script>
  document.querySelectorAll('.permalink-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-copy');
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
      btn.classList.add('copied');
      btn.setAttribute('title', 'Lien copié !');
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.setAttribute('title', 'Copier le lien');
      }, 2000);
    });
  });
</script>
