---
import { href } from '../lib/url.js';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const active = (p) => {
  const target = href(p).replace(/\/$/, '') || '/';
  return p === '/' ? path === target : path.startsWith(target);
};
---
<header class="site-header">
  <div class="container">
    <a class="brand" href={href('/')}>Delphine DBO</a>
    <nav class="nav">
      <a href={href('/')} aria-current={active('/') ? 'page' : undefined}>Accueil</a>
      <a href={href('/tags')} aria-current={active('/tags') ? 'page' : undefined}>Tags</a>
      <a href={href('/projects')} aria-current={active('/projects') ? 'page' : undefined}>Projets</a>
      <a href={href('/about')} aria-current={active('/about') ? 'page' : undefined}>À propos</a>
      <button id="theme-toggle" class="theme-toggle" aria-label="Changer de thème">
        <svg class="moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      </button>
    </nav>
  </div>
</header>
<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const el = document.documentElement;
    const next = el.dataset.theme === 'dark' ? 'light' : 'dark';
    el.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
