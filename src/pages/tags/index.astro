---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { href } from '../../lib/url.js';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const counts = {};
for (const p of posts) for (const t of p.data.tags) counts[t] = (counts[t] ?? 0) + 1;
const tags = Object.entries(counts).sort((a, b) => b[1] - a[1]);
---
<BaseLayout title="Tags" description="Tous les sujets abordés sur le site.">
  <h1>Tags</h1>
  <p class="muted">Explorer les articles par thème.</p>
  <div class="tags" style="margin-top:1.5rem">
    {tags.map(([t, n]) => <a class="tag" href={href(`/tags/${t}`)}>{t} · {n}</a>)}
  </div>
</BaseLayout>
